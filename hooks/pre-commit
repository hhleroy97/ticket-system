#!/usr/bin/env bash
# repo-intel pre-commit: refresh index + module docs when scan inputs change.
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if git diff --cached --name-only | grep -qE '^(scan\.py|\.env|templates/|test-repos/)'; then
  python3 scan.py
  python3 docgen.py
  git add docs/index.json docs/index.db docs/dashboard.html docs/modules/
fi

exit 0
