# Absolute path to the git repo you want to scan
TARGET_REPO=/path/to/your/repo

# Cursor API key for executor GitHub Actions, local cursor-agent, and serve_dashboard.py chat
CURSOR_API_KEY=

# Seconds between git fetch/sync while serve_dashboard.py is running (default 60)
SYNC_INTERVAL_SEC=60

# Dashboard live refresh (serve_dashboard.py only)
REFRESH_INTERVAL_SEC=15   # re-fetch GitHub PRs + issues
SCAN_INTERVAL_SEC=90      # full scan.py + github_intel
POLL_INDEX_MS=10000       # UI poll /api/index (ms)
POLL_ISSUES_MS=10000
POLL_WORKFLOWS_MS=4000
