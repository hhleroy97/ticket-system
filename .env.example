# Monitored repo for dependency graph and churn (defaults to this checkout if unset)
# For repo-intel self-analysis, point at this repository:
TARGET_REPO=/home/hartley/projects/personal/ticket-sys

# Intel checkout (this repo) always owns docs/ and GitHub pipeline metadata.
# Pre-commit hooks scan THIS repo only — never TARGET_REPO above.

# Cursor API key for executor GitHub Actions, local cursor-agent, and serve_dashboard.py chat
CURSOR_API_KEY=

# Seconds between git fetch/sync while serve_dashboard.py is running (default 60)
SYNC_INTERVAL_SEC=60

# Dashboard live refresh (serve_dashboard.py only)
REFRESH_INTERVAL_SEC=15   # re-fetch GitHub PRs + issues
SCAN_INTERVAL_SEC=90      # full scan.py (TARGET_REPO) + github_intel
POLL_INDEX_MS=10000       # UI poll /api/index (ms)
POLL_ISSUES_MS=10000
POLL_WORKFLOWS_MS=4000
